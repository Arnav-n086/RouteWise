# Copy this file to ".env" and fill in your real key.
# NEVER commit the real .env file to git — add ".env" to .gitignore.

FIREWORKS_API_KEY=your_fireworks_api_key_here

# Optional. Only affects HuggingFace downloads (router.py's grey-zone
# classifier, cache.py's semantic matching) — raises rate limits, not
# required for either feature to work. Get one at
# https://huggingface.co/settings/tokens (a "Read" token is enough).
HF_TOKEN=
